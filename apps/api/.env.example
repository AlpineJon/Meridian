# Postgres
DATABASE_URL=postgresql+asyncpg://meridian:meridian@localhost:5432/meridian
DATABASE_URL_SYNC=postgresql+psycopg://meridian:meridian@localhost:5432/meridian

# Redis
REDIS_URL=redis://localhost:6379/0

# API auth (prototype — single shared key; production would use SSO)
MERIDIAN_API_KEY=dev-meridian-key

# External APIs (free, but request keys for higher rate limits)
CENSUS_API_KEY=
BLS_API_KEY=
FRED_API_KEY=

# Feature flags
ENABLE_PAID_ADAPTERS=false
ATTOM_API_KEY=

# Cache TTLs (seconds)
CACHE_TTL_CENSUS=2592000      # 30 days
CACHE_TTL_ZILLOW=604800       # 7 days
CACHE_TTL_REALTOR=604800      # 7 days
CACHE_TTL_PERMITS=604800      # 7 days
CACHE_TTL_BLS=86400           # 1 day
CACHE_TTL_FRED=86400          # 1 day

# Logging
LOG_LEVEL=INFO
